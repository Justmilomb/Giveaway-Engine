# Raspberry Pi worker env

# Must match the server relay secret used by Render backend
SCRAPER_RELAY_SECRET=replace_with_shared_secret

# Your live domain websocket endpoint
SCRAPER_SERVER_URL=wss://pickusawinner.com

# Instagram account used for scraping
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# Headless mode for Pi
SCRAPER_HEADLESS=true

# Set this to the Chromium path on your Pi
# Run: which chromium-browser || which chromium
SCRAPER_EXECUTABLE_PATH=/usr/bin/chromium-browser
