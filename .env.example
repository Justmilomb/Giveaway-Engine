# Environment Variables for Giveaway Engine

# Optional but recommended on hosts with ephemeral filesystem:
# If set, the app will use PostgreSQL for persistent users/giveaways/ads.
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Apify API Token
# Get your token from: https://console.apify.com/account#/integrations
APIFY_TOKEN=your_apify_token_here

# SMTP Configuration for sending emails
# IMPORTANT:
# - SMTP_PASS must be an app password (not your account login password)
# - Keep SMTP_FROM the same as SMTP_USER unless your provider explicitly allows aliases
#
# iCloud Mail example:
# SMTP_HOST=smtp.mail.me.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@icloud.com
# SMTP_PASS=your_icloud_app_specific_password
# SMTP_FROM=you@icloud.com
#
# Gmail example:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=you@gmail.com
# SMTP_PASS=your_google_app_password
# SMTP_FROM=you@gmail.com
SMTP_HOST=smtp.mail.me.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@icloud.com
SMTP_PASS=your_app_specific_password
SMTP_FROM=your_email@icloud.com
SMTP_FROM_NAME=PickUsAWinner Support
SMTP_REPLY_TO=support@pickusawinner.com

# Admin API Key - Required for admin endpoints (analytics, token generation)
# Generate a secure random string
ADMIN_API_KEY=your_secure_admin_key_here

# Contact form - where submissions are sent (default: support@pickusawinner.com)
CONTACT_EMAIL=support@pickusawinner.com

# Optional: Base URL for email links (auto-detected if not set)
BASE_URL=https://your-domain.com

# Optional: Port to run the server on (default: 5000)
PORT=5000

# Optional but strongly recommended in production:
# Path to persistent JSON data file for users/giveaways/ads.
# On Render, set this to your mounted disk path (example):
# DATA_FILE=/var/data/db.json
DATA_FILE=db.json

# Local scraper worker (used by npm run scraper:worker / scraper:worker:pi)
SCRAPER_RELAY_SECRET=your_shared_relay_secret
# Optional: if set, used by worker -> server result callback auth.
# Falls back to SCRAPER_RELAY_SECRET when omitted.
SCRAPER_RESULT_SECRET=your_shared_relay_secret
SCRAPER_SERVER_URL=wss://pickusawinner.com
SCRAPER_JOBS_FILE=worker-jobs.json
INSTAGRAM_USERNAME=your_instagram_username
INSTAGRAM_PASSWORD=your_instagram_password

# Raspberry Pi/Linux ARM only (optional):
# Set if Chromium is not auto-detected.
# Common values: /usr/bin/chromium-browser or /usr/bin/chromium
SCRAPER_EXECUTABLE_PATH=/usr/bin/chromium-browser
